apiVersion: templates.gatekeeper.sh/v1
kind: ConstraintTemplate
metadata:
  name: k8sdenyrootuser
spec:
  crd:
    spec:
      names:
        kind: K8sDenyRootUser
      validation:
        openAPIV3Schema:
          type: object
          properties: {}
  targets:
    - target: admission.k8s.gatekeeper.sh
      rego: |
        package k8sdenyrootuser

        # Запрещаем явный root (runAsUser: 0)
        violation[{"msg": msg}] {
          input.review.kind.kind == "Pod"
          container := input.review.object.spec.containers[_]
          
          container.securityContext.runAsUser == 0
          msg := sprintf("Container %v explicitly runs as root (runAsUser=0)", [container.name])
        }

        # Запрещаем поды без явного non-root
        violation[{"msg": msg}] {
          input.review.kind.kind == "Pod"
          container := input.review.object.spec.containers[_]
          
          # Проверяем, что нет securityContext или он не обеспечивает non-root
          not security_context_ensures_non_root(container)
          
          msg := sprintf("Container %v must explicitly set runAsNonRoot: true or runAsUser > 0", [container.name])
        }

        # Вспомогательная функция: проверяет, что securityContext обеспечивает non-root
        security_context_ensures_non_root(container) {
          container.securityContext.runAsNonRoot == true
        }

        security_context_ensures_non_root(container) {
          container.securityContext.runAsUser > 0
        }

        # Проверяем initContainers
        violation[{"msg": msg}] {
          input.review.kind.kind == "Pod"
          container := input.review.object.spec.initContainers[_]
          
          container.securityContext.runAsUser == 0
          msg := sprintf("InitContainer %v explicitly runs as root (runAsUser=0)", [container.name])
        }

        violation[{"msg": msg}] {
          input.review.kind.kind == "Pod"
          container := input.review.object.spec.initContainers[_]
          
          not security_context_ensures_non_root(container)
          msg := sprintf("InitContainer %v must explicitly set runAsNonRoot: true or runAsUser > 0", [container.name])
        }
